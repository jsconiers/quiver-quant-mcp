# Quiver Quantitative API token. Get one at https://www.quiverquant.com/
# Some live feeds (congressional trading, the insider firehose) work without a
# token; most datasets require this key.
QUIVER_API_TOKEN=your_quiver_api_token_here

# Optional: override the Authorization scheme (Quiver uses "Token").
# QUIVER_AUTH_SCHEME=Token
